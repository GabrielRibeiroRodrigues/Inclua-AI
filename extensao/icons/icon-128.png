<svg width="128" height="128" viewBox="0 0 128 128" xmlns="http://www.w3.org/2000/svg">
  <!-- Fundo gradiente -->
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#667eea;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#764ba2;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Fundo -->
  <rect width="128" height="128" rx="24" fill="url(#grad)"/>
  
  <!-- Símbolo de acessibilidade (cadeira de rodas) -->
  <g transform="translate(64, 64)">
    <!-- Cabeça -->
    <circle cx="0" cy="-20" r="12" fill="white"/>
    
    <!-- Corpo -->
    <rect x="-8" y="-5" width="16" height="20" rx="4" fill="white"/>
    
    <!-- Braço esquerdo -->
    <line x1="-8" y1="0" x2="-25" y2="-10" stroke="white" stroke-width="4" stroke-linecap="round"/>
    
    <!-- Braço direito -->
    <line x1="8" y1="0" x2="25" y2="-10" stroke="white" stroke-width="4" stroke-linecap="round"/>
    
    <!-- Perna -->
    <line x1="0" y1="15" x2="0" y2="28" stroke="white" stroke-width="4" stroke-linecap="round"/>
  </g>
</svg>
